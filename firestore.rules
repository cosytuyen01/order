rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function ownsStore(storeId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    function isEmployeeOfStore(storeId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'employee'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.storeId == storeId;
    }

    function canAccessStore(storeId) {
      return ownsStore(storeId) || isEmployeeOfStore(storeId);
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && (
          request.auth.uid == userId
          || (
            request.resource.data.role == 'employee'
            && request.resource.data.storeId is string
            && ownsStore(request.resource.data.storeId)
          )
        );
      allow update: if isSignedIn()
        && (
          (
            request.auth.uid == userId
            && request.resource.data.role == resource.data.role
            && request.resource.data.storeId == resource.data.storeId
          )
          || (
            resource.data.role == 'employee'
            && resource.data.storeId is string
            && ownsStore(resource.data.storeId)
          )
        );

      match /fcmTokens/{tokenId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /stores/{storeId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if ownsStore(storeId);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isSignedIn()
        && canAccessStore(request.resource.data.storeId);
      allow update, delete: if isSignedIn()
        && canAccessStore(resource.data.storeId);
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn()
        && canAccessStore(request.resource.data.storeId);
      allow update, delete: if isSignedIn()
        && canAccessStore(resource.data.storeId);
    }

    match /tables/{tableId} {
      allow read: if true;
      allow create: if isSignedIn()
        && canAccessStore(request.resource.data.storeId);
      allow update, delete: if isSignedIn()
        && canAccessStore(resource.data.storeId);
    }

    match /orders/{orderId} {
      // Guests (customers at a table) need to read their order status live.
      allow read: if true;
      allow create: if true;
      allow update, delete: if isSignedIn()
        && canAccessStore(resource.data.storeId);
    }

    match /storeEvents/{eventId} {
      allow read: if isSignedIn()
        && canAccessStore(resource.data.storeId);
      allow create: if request.resource.data.keys().hasAll([
          'storeId',
          'tableId',
          'tableName',
          'type',
          'title',
          'body',
          'createdAt',
        ])
        && request.resource.data.type in ['qr_scan', 'cart_update', 'new_order']
        && exists(/databases/$(database)/documents/stores/$(request.resource.data.storeId));
      allow update, delete: if false;
    }

    match /tableCarts/{tableId} {
      function tableExists() {
        return exists(/databases/$(database)/documents/tables/$(tableId));
      }

      function tableStoreId() {
        return get(/databases/$(database)/documents/tables/$(tableId)).data.storeId;
      }

      allow read: if isSignedIn()
        && canAccessStore(resource.data.storeId);
      allow create, update: if tableExists()
        && request.resource.data.storeId == tableStoreId()
        && request.resource.data.tableId == tableId;
      allow delete: if tableExists()
        && (resource == null || resource.data.storeId == tableStoreId());
    }
  }
}
